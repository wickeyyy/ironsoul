-- ── Tab switching ─────────────────────────────────────────────────────────────
local tabs={
    Helmets={helmetPage,helmetTab,helmetTabL},
    Armor={armorPage,armorTab,armorTabL},
    Scrolls={scrollPage,scrollTab,scrollTabL},
    Weapons={weaponPage,weaponTab,weaponTabL},
}
local function switchTab(n)
    for k,v in pairs(tabs) do
        v[1].Visible=(k==n)
        TweenService:Create(v[2],TweenInfo.new(0.15),{BackgroundColor3=(k==n) and C.Accent or C.Card}):Play()
        v[3].TextColor3=(k==n) and C.Text or C.Sub
    end
end
helmetTab.MouseButton1Click:Connect(function()  switchTab("Helmets") end)
armorTab.MouseButton1Click:Connect(function()   switchTab("Armor")   end)
scrollTab.MouseButton1Click:Connect(function()  switchTab("Scrolls") end)
weaponTab.MouseButton1Click:Connect(function()  switchTab("Weapons") end)
switchTab("Helmets")

-- ── Drag ──────────────────────────────────────────────────────────────────────
do
    local drag,ds,wp
    TB.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true ds=i.Position wp=Win.Position end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-ds
            Win.Position=UDim2.new(wp.X.Scale,wp.X.Offset+d.X,wp.Y.Scale,wp.Y.Offset+d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)
end

