-- ── Generic scrollable item list ──────────────────────────────────────────────
local function buildListPage(data, columns, rowBuilder, defaultSort)
    local page = makePage()

    -- search bar
    local searchText = ""
    local _, searchTb = makeSearchBar(page, 0, function(txt) searchText = txt end)

    -- filter/sort bar
    local filterBar=Instance.new("Frame",page)
    filterBar.Size=UDim2.new(1,0,0,26) filterBar.Position=UDim2.new(0,0,0,32)
    filterBar.BackgroundTransparency=1 filterBar.BorderSizePixel=0
    local filterLayout=Instance.new("UIListLayout",filterBar)
    filterLayout.FillDirection=Enum.FillDirection.Horizontal filterLayout.Padding=UDim.new(0,3)

    -- table header
    local headerFrame=Instance.new("Frame",page)
    headerFrame.Size=UDim2.new(1,0,0,24) headerFrame.Position=UDim2.new(0,0,0,62)
    headerFrame.BackgroundColor3=C.Panel headerFrame.BorderSizePixel=0
    Instance.new("UICorner",headerFrame).CornerRadius=UDim.new(0,6)

    local xOff = 0
    for _, col in ipairs(columns) do
        local lbl=Instance.new("TextLabel",headerFrame)
        lbl.Size=UDim2.new(0,col.w,1,0) lbl.Position=UDim2.new(0,xOff,0,0)
        lbl.BackgroundTransparency=1 lbl.Text=col.name
        lbl.TextColor3=C.Sub lbl.TextSize=9 lbl.Font=Enum.Font.GothamBold
        lbl.TextXAlignment=Enum.TextXAlignment.Left
        xOff = xOff + col.w
    end

    -- scroll area
    local bg=Instance.new("Frame",page) bg.Size=UDim2.new(1,0,0,400)
    bg.Position=UDim2.new(0,0,0,90) bg.BackgroundColor3=C.Card
    bg.BorderSizePixel=0 bg.ClipsDescendants=true
    Instance.new("UICorner",bg).CornerRadius=UDim.new(0,8)
    Instance.new("UIStroke",bg).Color=C.Border

    local sc=Instance.new("ScrollingFrame",bg)
    sc.Size=UDim2.new(1,-4,1,-4) sc.Position=UDim2.new(0,2,0,2)
    sc.BackgroundTransparency=1 sc.BorderSizePixel=0
    sc.ScrollBarThickness=2 sc.ScrollBarImageColor3=C.Accent
    local lay=Instance.new("UIListLayout",sc)
    lay.Padding=UDim.new(0,1) lay.SortOrder=Enum.SortOrder.LayoutOrder

    local allItems = {}
    for k, v in pairs(data) do
        if type(v)=="table" and v.ID then
            table.insert(allItems, v)
        end
    end

    local activeFilters = {}
    local sortMode = defaultSort or "default"

    local function refresh()
        for _, child in pairs(sc:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end

        -- filter + search
        local filtered = {}
        for _, item in ipairs(allItems) do
            local txt = searchText:lower()
            local nameMatch = item.ID:lower():find(txt, 1, true) or txt==""
            local classMatch = next(activeFilters)==nil or activeFilters[item.Class or item.WeaponClass or ""]
            if nameMatch and classMatch then
                table.insert(filtered, item)
            end
        end

        -- sort
        if sortMode=="hp_asc" then
            table.sort(filtered, function(a,b) return (a.HP or a.AttackDamage or 0) < (b.HP or b.AttackDamage or 0) end)
        elseif sortMode=="hp_desc" then
            table.sort(filtered, function(a,b) return (a.HP or a.AttackDamage or 0) > (b.HP or b.AttackDamage or 0) end)
        elseif sortMode=="price_asc" then
            table.sort(filtered, function(a,b) return (a.Price or 0) < (b.Price or 0) end)
        elseif sortMode=="price_desc" then
            table.sort(filtered, function(a,b) return (a.Price or 0) > (b.Price or 0) end)
        elseif sortMode=="tier" then
            table.sort(filtered, function(a,b) return (a.T or 0) < (b.T or 0) end)
        elseif sortMode=="rarity" then
            table.sort(filtered, function(a,b) return (a.Rarity or 0) < (b.Rarity or 0) end)
        end

        for i, item in ipairs(filtered) do
            rowBuilder(sc, item, i)
        end
        sc.CanvasSize = UDim2.new(0,0,0,#filtered*30+4)
        countLbl.Text = "Items: "..#filtered.."/"..#allItems
        filterLbl.Text = "Filter: "..(next(activeFilters) and table.concat((function() local t={} for k in pairs(activeFilters) do table.insert(t,k) end return t end)(),",") or "All")
        sortLbl.Text = "Sort: "..sortMode
    end

    searchTb:GetPropertyChangedSignal("Text"):Connect(refresh)

    -- sort buttons
    local sorts = {{"HP↑","hp_desc"},{"HP↓","hp_asc"},{"Price↑","price_desc"},{"Price↓","price_asc"},{"Tier","tier"},{"Rarity","rarity"}}
    for i, s in ipairs(sorts) do
        local b=Instance.new("TextButton",filterBar)
        b.Size=UDim2.new(0,52,1,0) b.BackgroundColor3=C.Card b.Text=s[1]
        b.TextColor3=C.Sub b.TextSize=9 b.Font=Enum.Font.GothamBold b.BorderSizePixel=0
        Instance.new("UICorner",b).CornerRadius=UDim.new(0,5)
        b.MouseButton1Click:Connect(function()
            sortMode=s[2]
            for _, btn in pairs(filterBar:GetChildren()) do
                if btn:IsA("TextButton") then
                    btn.BackgroundColor3=C.Card btn.TextColor3=C.Sub
                end
            end
            b.BackgroundColor3=C.Accent b.TextColor3=Color3.new(1,1,1)
            refresh()
        end)
    end

    refresh()
    return page, refresh, activeFilters
end

