    atkLbl.Size=UDim2.new(0,55,1,0) atkLbl.Position=UDim2.new(0,276,0,0)
    atkLbl.BackgroundTransparency=1 atkLbl.Text="⚔️ "..(item.AttackDamage or "?")
    atkLbl.TextColor3=Color3.fromRGB(255,140,80) atkLbl.TextSize=10 atkLbl.Font=Enum.Font.Gotham
    atkLbl.TextXAlignment=Enum.TextXAlignment.Left

    local priceLbl=Instance.new("TextLabel",row)
    priceLbl.Size=UDim2.new(0,50,1,0) priceLbl.Position=UDim2.new(0,334,0,0)
    priceLbl.BackgroundTransparency=1 priceLbl.Text="💰 "..(item.Price or "?")
    priceLbl.TextColor3=C.Gold priceLbl.TextSize=10 priceLbl.Font=Enum.Font.Gotham
